[Server]
SystemLogFile=/var/log/archspace/system.log
PIDLogfile=/var/run/archspace.pid
Port=12345

[Database]
Host=db
User=archspace
Password=archspace
Database=Archspace2
PortalUserDB=Archspace2
PortalUserTable=asbb_users

[Game]
WebPath=/var/archspace/web
NewsFileDir=/var/archspace/news
ImageServerURL=http://localhost:12345
ForumServerURL=http://localhost:12345/forum
StartGame=true
SecondPerTurn=60
Language=en
TechScript=/var/archspace/script/tech.en
RaceScript=/var/archspace/script/race.en
AdmiralNameScript=/var/archspace/script/admiral_name.en
ProjectScript=/var/archspace/script/project.en
SecretProjectScript=/var/archspace/script/secret_project.en
EndingProjectScript=/var/archspace/script/ending_project
EndingScript=/var/archspace/script/ending.en
ComponentScript=/var/archspace/script/component.en
ShipScript=/var/archspace/script/ship.en
SpyScript=/var/archspace/script/spy.en
EventScript=/var/archspace/script/event.en
ClusterNames=/var/archspace/script/cluster.en
EmpireShipDesignScript=/var/archspace/script/empire_ship_design
EncyclopediaFormPath=/var/archspace/form/encyclopedia
EncyclopediaPath=/var/archspace/web/encyclopedia
# URL prefix used when generating links into the encyclopedia — must be a path, not a filesystem path
EncyclopediaWebPath=/encyclopedia

# All periods below are in TURNS. Each turn = SecondPerTurn seconds (60s here).
# Original game ran at 900s/turn; values below preserve the same turn counts
# so real durations scale proportionally with SecondPerTurn.
#
# Diplomatic cooldowns (turns × 60s):
#   288 turns = 4.8h   |   96 turns = 1.6h
PeriodPlayerDeclareHostile=288
PeriodPlayerBreakPact=288
PeriodPlayerBreakAlly=288
PeriodPlayerCouncilDonation=96
PeriodCouncilDeclareTotalWar=288
PeriodCouncilDeclareWar=96
PeriodCouncilBreakPact=288
PeriodCouncilBreakAlly=288
PeriodCouncilImproveRelation=288

# Fleet mission durations (turns × 60s):
#   TrainMissionTime         24 turns = 24 min
#   PatrolMissionTime        96 turns = 96 min
#   DispatchToAllyMissionTime 288 turns = 4.8h
#   ExpeditionMissionTime    24 turns = 24 min
#   ReturningWithPlanetMissionTime 24 turns = 24 min
# (Without these the compiled defaults are 24×900s, 96×900s, etc. — they
#  stay fixed at those second counts regardless of SecondPerTurn.)
TrainMissionTime=24
PatrolMissionTime=96
DispatchToAllyMissionTime=288
ExpeditionMissionTime=24
ReturningWithPlanetMissionTime=24

# Admiral creation cooldown (in turns — counts up once per turn tick):
#   24 turns = 24 min between new admirals
PeriodCreateAdmiral=24

[Banner]
Path=/var/archspace/web
TopBanner=
BottomBanner=
